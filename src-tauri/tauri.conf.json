{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flashback",
  "version": "1.1.0",
  "identifier": "com.flashback.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Flashback",
        "width": 1200,
        "height": 675,
        "minWidth": 1200,
        "minHeight": 675,
        "decorations": false,
        "shadow": true
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "width": 480,
        "height": 64,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "resizable": false,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/clips/*", "$APPDATA/thumbs/*", "$APPDATA/audio/*", "$APPDATA/screenshots/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
