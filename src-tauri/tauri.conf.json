{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flashback",
  "version": "1.4.0",
  "identifier": "com.flashback.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Flashback",
        "width": 1200,
        "height": 675,
        "minWidth": 1200,
        "minHeight": 675,
        "decorations": false,
        "shadow": true,
        "visible": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "width": 480,
        "height": 64,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "resizable": false,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/clips/*", "$APPDATA/thumbs/*", "$APPDATA/audio/*", "$APPDATA/screenshots/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "installer.nsh"
      },
      "wix": {
        "fragmentPaths": ["autostart.wxs"],
        "componentRefs": ["FlashbackAutostart"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2NjFFNEY3MUQ1NjU3M0YKUldRL1YxWWQ5K1JoWm53UUdLMTBweTV6emRzc05ib0RBaGRkZnkxZHkvS29kcEdtc2l6cnFGWnoK",
      "endpoints": [
        "https://github.com/kuzpire/Flashback/releases/latest/download/latest.json"
      ]
    }
  }
}
